{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "esnext",
    "target": "es2024",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "paths": {
      "#cli/*": ["./*"],
      "#server/*": ["../server/*"],
      "#db/*": ["../server/database/*"]
    }
  },
  "include": ["./**/*.ts"]
}
