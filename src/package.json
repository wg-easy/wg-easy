    "@nuxtjs/tailwindcss": "^6.14.0",
    "@phc/format": "^1.0.0",
    "@pinia/nuxt": "^1.0.1",
    "@tailwindcss/forms": "^0.5.11",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "apexcharts": "^6.3.0",
    "argon2": "^0.45.0",
    "cidr-tools": "^12.1.2",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "crc-32": "^1.2.2",
    "drizzle-orm": "^0.45.2",
    "ip-bigint": "^9.0.6",
    "is-cidr": "^7.0.0",
    "is-ip": "^5.0.1",
    "js-sha256": "^0.12.0",
    "nuxt": "^4.5.0",
    "obug": "^2.1.4",
    "openid-client": "^6.8.4",
    "otpauth": "^9.5.1",
    "pinia": "^4.0.2",
    "qr": "^0.6.0",
    "radix-vue": "^1.9.17",
    "semver": "^7.8.5",
    "tailwindcss": "^3.4.19",
    "timeago.js": "^4.0.2",
    "vue": "latest",
